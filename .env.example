# ──────────────────────────────────────────────
# A2LM Gateway — Environment Configuration
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────

# Gateway
SECRET_KEY=change-me-to-a-random-32-char-string
GATEWAY_API_KEY=your-personal-gateway-key       # The key YOU use to call the gateway

# Database
DATABASE_URL=postgresql+asyncpg://a2lm:a2lm@postgres:5432/a2lm

# Redis
REDIS_URL=redis://redis:6379/0

# ── Provider API Keys ──
# Get free keys at:
#   Groq        → https://console.groq.com
#   OpenRouter  → https://openrouter.ai
#   Google AI   → https://aistudio.google.com (get API key from top-right)

GROQ_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_AI_STUDIO_API_KEY=
CEREBRAS_API_KEY=         

# Optional: add multiple keys per provider for quota rotation (comma-separated)
# GROQ_API_KEYS=key1,key2,key3
# OPENROUTER_API_KEYS=key1,key2
# GOOGLE_AI_STUDIO_API_KEYS=key1,key2
# CEREBRAS_API_KEYS=key1,key2   # optional multi-key rotation


# Get from: https://dash.cloudflare.com → Workers & Pages → Overview
# Account ID is in the right sidebar of your dashboard
CLOUDFLARE_ACCOUNT_ID=your-32-char-account-id

# Get from: https://dash.cloudflare.com → My Profile → API Tokens
# Create token with "Cloudflare Workers AI" permission
CLOUDFLARE_API_KEY=your-cf-api-token

# https://dashboard.cohere.com → API Keys → Create trial key
COHERE_API_KEY=your-cohere-key

# https://console.mistral.ai → API Keys → Create key
# Note: free tier requires opting into data training on signup
MISTRAL_API_KEY=your-mistral-key

# 1. Go to https://build.nvidia.com
# 2. Click any model → "Get API Key"
# 3. Phone verification required (one time)
NVIDIA_API_KEY=nvapi-...

# Logging
LOG_LEVEL=INFO
