# ──────────────────────────────────────────────
# OMNI-LLM Gateway — Environment Configuration
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────

# Gateway
SECRET_KEY=change-me-to-a-random-32-char-string
GATEWAY_API_KEY=your-personal-gateway-key       # The key YOU use to call the gateway

# Database
DATABASE_URL=postgresql+asyncpg://omnillm:omnillm@postgres:5432/omnillm

# Redis
REDIS_URL=redis://redis:6379/0

# ── Provider API Keys ──
# Get free keys at:
#   Groq        → https://console.groq.com
#   OpenRouter  → https://openrouter.ai
#   Google AI   → https://aistudio.google.com (get API key from top-right)

GROQ_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_AI_STUDIO_API_KEY=

# Optional: add multiple keys per provider for quota rotation (comma-separated)
# GROQ_API_KEYS=key1,key2,key3
# OPENROUTER_API_KEYS=key1,key2
# GOOGLE_AI_STUDIO_API_KEYS=key1,key2

# Logging
LOG_LEVEL=INFO
